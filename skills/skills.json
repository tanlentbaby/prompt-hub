      "template": true
    },
    {
      "name": "prompt-search",
      "alias": "ps",
      "description": "搜索 Prompt Hub 模板（支持中文关键词）",
      "file": "prompt-search.md",
      "template": true
    },
    {
      "name": "prompt-show",
      "alias": "psh",
      "description": "查看 Prompt Hub 模板详情和变量",
      "file": "prompt-show.md",
      "template": true
    },
    {
      "name": "prompt-fill",
      "alias": "pf",
      "description": "填充 Prompt Hub 模板生成最终提示词",
      "file": "prompt-fill.md",
      "template": true
    },
    {
      "name": "prompt-add",
      "alias": "pa",
      "description": "添加新的提示词模板到 Prompt Hub",
      "file": "prompt-add.md",
      "template": true
