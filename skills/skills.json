{
  "name": "Prompt Hub Skills",
  "version": "4.0",
  "description": "Prompt Hub 快捷命令，支持 50+ 模板和扩展能力",
  "skills": [
    {
      "name": "prompt-list",
      "alias": "pl",
      "description": "列出所有 Prompt Hub 模板或指定分类",
