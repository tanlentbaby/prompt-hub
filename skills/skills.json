    {
      "name": "prompt-new",
      "alias": "pn",
      "description": "创建新的提示词模板（交互式向导）",
      "file": "prompt-new.md",
      "template": true
    },
    {
      "name": "prompt-register",
      "alias": "pr",
      "description": "注册模板文件到 Prompt Hub 系统",
      "file": "prompt-register.md",
      "template": true
    },
    {
      "name": "prompt-template",
      "alias": "pt",
      "description": "模板生成器 - 根据需求自动生成模板",
