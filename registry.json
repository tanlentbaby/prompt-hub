{
  "version": "2.0.0",
  "templates": {
    "code_gen": {
      "function": {
        "path": "code_gen/function.md",
        "description": "生成函数/方法代码",
        "variables": [
          "language",
          "function_name",
          "description",
          "params",
          "returns",
          "examples"
        ]
      },
      "class": {
        "path": "code_gen/class.md",
        "description": "生成类定义",
        "variables": [
          "language",
          "class_name",
          "description",
          "methods",
          "attributes"
        ]
      },
      "api": {
        "path": "code_gen/api.md",
        "description": "生成 API 端点",
        "variables": [
          "framework",
          "endpoints",
          "models",
          "auth_type"
        ]
      },
      "refactor": {
        "path": "code_gen/refactor.md",
        "description": "代码重构/优化",
        "variables": [
          "code",
          "issues",
          "goals",
          "constraints"
        ]
      },
      "sql": {
        "path": "code_gen/sql.md",
        "description": "生成 SQL 查询",
        "variables": [
          "query_description",
          "db_type",
          "table_schema"
        ]
      },
      "unit_test": {
        "path": "code_gen/unit_test.md",
        "description": "生成单元测试",
        "variables": [
          "code",
          "language",
          "test_framework",
          "mock_requirements"
        ]
      },
      "code_review": {
        "path": "code_gen/code_review.md",
        "description": "代码审查 Checklist",
        "variables": [
          "code",
          "language"
        ]
      },
      "commit_message": {
        "path": "code_gen/commit_message.md",
        "description": "生成 Git Commit Message",
        "variables": [
          "changes_description",
          "issue",
          "breaking"
        ]
      },
      "dockerfile": {
        "path": "code_gen/dockerfile.md",
        "description": "生成 Dockerfile",
        "variables": [
          "application_description",
          "language",
          "framework",
          "port",
          "dependencies"
        ]
      }
    },
    "data_analysis": {
      "eda": {
        "path": "data_analysis/eda.md",
        "description": "探索性数据分析",
        "variables": [
          "data_source",
          "columns",
          "analysis_goals",
          "output_format"
        ]
      },
      "cleaning": {
        "path": "data_analysis/cleaning.md",
        "description": "数据清洗流程",
        "variables": [
          "data_issues",
          "cleaning_rules",
          "validation"
        ]
      },
      "visualization": {
        "path": "data_analysis/visualization.md",
        "description": "数据可视化",
        "variables": [
          "chart_type",
          "data",
          "x_axis",
          "y_axis",
          "style"
        ]
      },
      "ml_pipeline": {
        "path": "data_analysis/ml_pipeline.md",
        "description": "机器学习管道",
        "variables": [
          "task_type",
          "features",
          "target",
          "models",
          "metrics"
        ]
      },
      "sql_analysis": {
        "path": "data_analysis/sql_analysis.md",
        "description": "SQL 数据分析",
        "variables": [
          "analysis_goal",
          "db_type",
          "tables",
          "time_range",
          "metrics"
        ]
      },
      "excel_formula": {
        "path": "data_analysis/excel_formula.md",
        "description": "Excel 公式生成",
        "variables": [
          "problem_description",
          "range",
          "data_structure",
          "expected_result"
        ]
      },
      "regex": {
        "path": "data_analysis/regex.md",
        "description": "正则表达式生成",
        "variables": [
          "task_description",
          "input_example",
          "expected_match",
          "language"
        ]
      },
      "json_yaml": {
        "path": "data_analysis/json_yaml.md",
        "description": "JSON/YAML 处理",
        "variables": [
          "task_type",
          "input_format",
          "input_data",
          "output_format"
        ]
      }
    },
    "docs": {
      "readme": {
        "path": "docs/readme.md",
        "description": "README 文档生成",
